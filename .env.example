# LLM — провайдер: claude-code (локальный CLI, без ключа) | openai
LLM_PROVIDER=claude-code
CLAUDE_MODEL_ANALYZE=haiku    # анализ + стоп-правила — быстро и трезво
CLAUDE_MODEL_COMPOSE=sonnet   # текст подрядчику — качественнее
# для LLM_PROVIDER=openai (или OpenRouter-совместимого):
OPENAI_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o

# Google Sheets
GOOGLE_CREDENTIALS_PATH=config/google_credentials.json
SHEET_NAME=VendorFlow
SHEET_ID=              # ID таблицы; расшарить на сервисный аккаунт как Editor

# Telethon (user-сессия для первого сообщения) — my.telegram.org/apps
TG_API_ID=
TG_API_HASH=
TG_PHONE=              # телефон аккаунта-отправителя для разового логина (python auth.py)
TG_SESSION=config/vendorflow.session

# Бот менеджера — токен от @BotFather
MANAGER_BOT_TOKEN=
MANAGER_CHAT_ID=       # ваш Telegram user_id (узнать у @userinfobot)

# Safety
DRY_RUN=true
KILL_SWITCH=false
TEST_RUN=false         # тестовый прогон: обходит рабочие часы, паузы и лимиты (kill_switch всё равно работает)

# Планировщик
WORK_HOURS_START=10
WORK_HOURS_END=18
MAX_NEW_CONTACTS_PER_DAY=15
MAX_MESSAGES_PER_CONTACT_PER_DAY=3
